{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "composite": true,
    "baseUrl": ".",
    "paths": {
      "@wpx/types": ["packages/types/src/index.ts"],
      "@wpx/core": ["packages/core/src/index.ts"],
      "@wpx/db": ["packages/db/src/index.ts"]
    }
  },
  "exclude": ["node_modules", "dist", "build", ".astro"]
}
